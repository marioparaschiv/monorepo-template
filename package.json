{
	"name": "monorepo-template",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "pnpm -r --filter \"./apps/*\" --parallel --if-present run dev",
		"build": "pnpm -r --filter \"./packages/*\" --if-present run build && pnpm -r --filter \"./apps/*\" --if-present run build",
		"prepare": "husky",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint --config .oxlintrc.json --fix-dangerously apps packages",
		"fmt": "oxfmt --config .oxfmtrc.json apps packages",
		"fmt:check": "oxfmt --config .oxfmtrc.json --check apps packages",
		"typecheck": "pnpm -r --if-present run typecheck"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-angular": "20.5.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:",
		"@vitest/coverage-v8": "4.1.4",
		"eslint-plugin-perfectionist": "^5.7.0",
		"husky": "9.1.7",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"tsdown": "^0.21.7",
		"tsx": "^4.20.6",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=11.1.0 <12"
	}
}
